# =========================
# WiFi AP for clients
# =========================
AP_SSID=pi_travel_router
AP_PASS=CHANGE_ME_LONG_RANDOM_PASSWORD
AP_CHANNEL=6

AP_IP=192.168.50.1
AP_DHCP_START=192.168.50.10
AP_DHCP_END=192.168.50.100

# =========================
# Ethernet client LAN
# only used when eth0 is not the uplink
# =========================
ETH_CLIENT_IP=192.168.60.1
ETH_CLIENT_DHCP_START=192.168.60.10
ETH_CLIENT_DHCP_END=192.168.60.100

# =========================
# System
# =========================
WIFI_COUNTRY=AU
INSTALL_TAILSCALE=true

# Leave blank for auto-detect.
# Examples: usb0, eth0, eth1, enx001122334455
UPLINK_IF=

# =========================
# Tailscale
# =========================
# Required for:
#   pi-router tailscale-exit
#   pi-router tunnel
#
# Example:
#   HOME_EXIT_NODE=network-exit-node-device
HOME_EXIT_NODE=

# =========================
# Security
# =========================
# false = clients cannot SSH to the Pi directly
# SSH should be via Tailscale only
ALLOW_CLIENT_SSH=false

# true = tunnel mode only allows client traffic through tailscale0
FAIL_CLOSED=true

# =========================
# Boot mode
# =========================
# up     = normal WAN routing on boot
# tunnel = Tailscale exit node + fail-closed tunnel routing on boot
BOOT_MODE=up
